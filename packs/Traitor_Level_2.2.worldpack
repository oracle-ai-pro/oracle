ProphecySystem.Prophet
{"repeatable":false,"prophecyStrings":["{\"performers\":[3],\"lumiTalking\":false,\"redTalking\":false,\"greenTalking\":true,\"blueTalking\":false,\"purpleTalking\":false,\"dialogue\":\"А ой, вы кто?[1.2] Или знаю кто это,\",\"endWait\":30.0,\"playerSkippable\":true,\"runParallel\":false,\"continueAutomatically\":true}","{\"performers\":[1],\"lumiTalking\":true,\"redTalking\":false,\"greenTalking\":false,\"blueTalking\":false,\"purpleTalking\":false,\"dialogue\":\"Я Люми.\",\"endWait\":30.0,\"playerSkippable\":true,\"runParallel\":false,\"continueAutomatically\":true}","{\"performers\":[3],\"lumiTalking\":false,\"redTalking\":false,\"greenTalking\":true,\"blueTalking\":false,\"purpleTalking\":false,\"dialogue\":\"Фух. А то я думала, что это опять Фиолетовая Кошка меня убить собралась\",\"endWait\":30.0,\"playerSkippable\":true,\"runParallel\":false,\"continueAutomatically\":true}","{\"performers\":[1],\"lumiTalking\":true,\"redTalking\":false,\"greenTalking\":false,\"blueTalking\":false,\"purpleTalking\":false,\"dialogue\":\"Я могу подойти к тебе ближе?\",\"endWait\":30.0,\"playerSkippable\":true,\"runParallel\":false,\"continueAutomatically\":true}","{\"performers\":[3],\"lumiTalking\":false,\"redTalking\":false,\"greenTalking\":true,\"blueTalking\":false,\"purpleTalking\":false,\"dialogue\":\"Да да, конечно \",\"endWait\":30.0,\"playerSkippable\":true,\"runParallel\":false,\"continueAutomatically\":true}","{\"performers\":[1],\"lumiMoving\":true,\"redMoving\":false,\"greenMoving\":false,\"blueMoving\":false,\"purpleMoving\":false,\"moveType\":10,\"duration\":0.0,\"runParallel\":false}"],"prophecyTypeStrings":["ProphecySystem.TalkProphecy","ProphecySystem.TalkProphecy","ProphecySystem.TalkProphecy","ProphecySystem.TalkProphecy","ProphecySystem.TalkProphecy","ProphecySystem.MoveProphecy"],"removePlayerControlUntilTold":true,"companionActivated":false}

