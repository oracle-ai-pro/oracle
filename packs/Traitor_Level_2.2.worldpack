PolyMap.Shape
{"pointData":[{"position":{"x":82.0,"y":2.0},"curved":false},{"position":{"x":82.0,"y":6.0},"curved":false},{"position":{"x":83.0,"y":6.0},"curved":false},{"position":{"x":83.0,"y":2.0},"curved":false}]}
ProphecySystem.Prophet
{"repeatable":false,"prophecyStrings":["{\"performers\":[1],\"lumiMoving\":true,\"redMoving\":false,\"greenMoving\":false,\"blueMoving\":false,\"purpleMoving\":false,\"moveType\":0,\"duration\":0.0,\"runParallel\":false}","{\"performers\":[1],\"lumiTalking\":true,\"redTalking\":false,\"greenTalking\":false,\"blueTalking\":false,\"purpleTalking\":false,\"dialogue\":\"Меня, попросили тебя забрать, я пыталась, но меня поймала Фиолетовая Кошка, я потеряла сознание и очнулась иза Ветра уже  В клетке.\",\"endWait\":79.0,\"playerSkippable\":true,\"runParallel\":false,\"continueAutomatically\":true}","{\"performers\":[1],\"lumiTalking\":true,\"redTalking\":false,\"greenTalking\":false,\"blueTalking\":false,\"purpleTalking\":false,\"dialogue\":\"У меня ещё была кнопка, для управления дверьми! а тут ее нету.\",\"endWait\":30.0,\"playerSkippable\":true,\"runParallel\":false,\"continueAutomatically\":true}","{\"performers\":[3],\"lumiTalking\":false,\"redTalking\":false,\"greenTalking\":true,\"blueTalking\":false,\"purpleTalking\":false,\"dialogue\":\"Да, у меня никаких кнопок, нету. Об шипы ударится уж слишком... С последствиями останусь...\",\"endWait\":28.0,\"playerSkippable\":true,\"runParallel\":false,\"continueAutomatically\":true}","{\"performers\":[1],\"lumiTalking\":true,\"redTalking\":false,\"greenTalking\":false,\"blueTalking\":false,\"purpleTalking\":false,\"dialogue\":\"Нам нужно сбежать отсюда, скорее\",\"endWait\":30.0,\"playerSkippable\":true,\"runParallel\":false,\"continueAutomatically\":true}","{\"performers\":[1],\"lumiTalking\":true,\"redTalking\":false,\"greenTalking\":false,\"blueTalking\":false,\"purpleTalking\":false,\"dialogue\":\"Я могу отключить все препятствия.\",\"endWait\":30.0,\"playerSkippable\":true,\"runParallel\":false,\"continueAutomatically\":true}","{\"performers\":[3],\"lumiTalking\":false,\"redTalking\":false,\"greenTalking\":true,\"blueTalking\":false,\"purpleTalking\":false,\"dialogue\":\"Гениальная Идея!\",\"endWait\":30.0,\"playerSkippable\":true,\"runParallel\":false,\"continueAutomatically\":true}","{\"performers\":[1],\"lumiTalking\":true,\"redTalking\":false,\"greenTalking\":false,\"blueTalking\":false,\"purpleTalking\":false,\"dialogue\":\"Пожелай удачи!\",\"endWait\":30.0,\"playerSkippable\":true,\"runParallel\":false,\"continueAutomatically\":true}","{\"duration\":70.0}","{\"performers\":[3],\"lumiTalking\":false,\"redTalking\":false,\"greenTalking\":true,\"blueTalking\":false,\"purpleTalking\":false,\"dialogue\":\"У тебя там все получается?\",\"endWait\":30.0,\"playerSkippable\":true,\"runParallel\":false,\"continueAutomatically\":true}","{\"duration\":48.0}","{\"connectedButtonGUID\":\"2b77f9b7-8c95-446d-aac8-61b2f54a20ce\"}","{\"performers\":[1,3],\"lumiTalking\":true,\"redTalking\":false,\"greenTalking\":true,\"blueTalking\":false,\"purpleTalking\":false,\"dialogue\":\"О ура!\",\"endWait\":30.0,\"playerSkippable\":true,\"runParallel\":false,\"continueAutomatically\":true}","{\"performers\":[3],\"lumiTalking\":false,\"redTalking\":false,\"greenTalking\":true,\"blueTalking\":false,\"purpleTalking\":false,\"dialogue\":\"Тогда я через канализацию сбегаю.\",\"endWait\":30.0,\"playerSkippable\":true,\"runParallel\":false,\"continueAutomatically\":true}","{\"performers\":[3],\"lumiMoving\":false,\"redMoving\":false,\"greenMoving\":true,\"blueMoving\":false,\"purpleMoving\":false,\"moveType\":20,\"duration\":0.0,\"runParallel\":false}"],"prophecyTypeStrings":["ProphecySystem.MoveProphecy","ProphecySystem.TalkProphecy","ProphecySystem.TalkProphecy","ProphecySystem.TalkProphecy","ProphecySystem.TalkProphecy","ProphecySystem.TalkProphecy","ProphecySystem.TalkProphecy","ProphecySystem.TalkProphecy","ProphecySystem.WaitProphecy","ProphecySystem.TalkProphecy","ProphecySystem.WaitProphecy","ProphecySystem.ButtonProphecy","ProphecySystem.TalkProphecy","ProphecySystem.TalkProphecy","ProphecySystem.MoveProphecy"],"removePlayerControlUntilTold":true,"companionActivated":false}

