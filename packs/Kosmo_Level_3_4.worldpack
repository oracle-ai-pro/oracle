{"repeatable":false,"prophecyStrings":["{\"performers\":[1],\"lumiMoving\":true,\"redMoving\":false,\"greenMoving\":false,\"blueMoving\":false,\"purpleMoving\":false,\"moveType\":0,\"duration\":0.0,\"runParallel\":true}","{\"performers\":[3],\"lumiTalking\":false,\"redTalking\":false,\"greenTalking\":true,\"blueTalking\":false,\"purpleTalking\":false,\"dialogue\":\"Не иди туда!\",\"endWait\":0.0,\"playerSkippable\":false,\"runParallel\":true,\"continueAutomatically\":true}","{\"performers\":[5],\"lumiTalking\":false,\"redTalking\":false,\"greenTalking\":false,\"blueTalking\":false,\"purpleTalking\":true,\"dialogue\":\"Ну что ты наконец то попалась, Люми!\",\"endWait\":34.0,\"playerSkippable\":true,\"runParallel\":false,\"continueAutomatically\":true}","{\"performers\":[5],\"lumiTalking\":false,\"redTalking\":false,\"greenTalking\":false,\"blueTalking\":false,\"purpleTalking\":true,\"dialogue\":\"Я наконец то дождалась твоего прохождения!\",\"endWait\":0.0,\"playerSkippable\":true,\"runParallel\":true,\"continueAutomatically\":true}","{\"effectType\":1,\"duration\":3.0,\"runParallel\":false}","{\"performers\":[5],\"lumiTalking\":false,\"redTalking\":false,\"greenTalking\":false,\"blueTalking\":false,\"purpleTalking\":true,\"dialogue\":\"Твои настоящие друзья мне просто помогли и я их отпустила раньше на свободу!\",\"endWait\":41.0,\"playerSkippable\":false,\"runParallel\":false,\"continueAutomatically\":true}","{\"performers\":[5],\"lumiTalking\":false,\"redTalking\":false,\"greenTalking\":false,\"blueTalking\":false,\"purpleTalking\":true,\"dialogue\":\"Здесь я вижу что устала, Да?\",\"endWait\":30.0,\"playerSkippable\":false,\"runParallel\":false,\"continueAutomatically\":true}","{\"performers\":[1],\"lumiEmoting\":true,\"redEmoting\":false,\"greenEmoting\":false,\"blueEmoting\":false,\"purpleEmoting\":false,\"emoteType\":5,\"duration\":10.0,\"runParallel\":true}","{\"duration\":5.0}","{\"performers\":[5],\"lumiTalking\":false,\"redTalking\":false,\"greenTalking\":false,\"blueTalking\":false,\"purpleTalking\":true,\"dialogue\":\"А ну понятно что твое прохождение было таким интересным. Что по тебе это видно\",\"endWait\":30.0,\"playerSkippable\":false,\"runParallel\":false,\"continueAutomatically\":true}","{\"performers\":[5],\"lumiTalking\":false,\"redTalking\":false,\"greenTalking\":false,\"blueTalking\":false,\"purpleTalking\":true,\"dialogue\":\"Ну нечего страшного, сейчас тебе предстоит пройти воспоминания. Так как мне просто хочется \",\"endWait\":30.0,\"playerSkippable\":false,\"runParallel\":false,\"continueAutomatically\":true}","{\"performers\":[1],\"lumiEmoting\":true,\"redEmoting\":false,\"greenEmoting\":false,\"blueEmoting\":false,\"purpleEmoting\":false,\"emoteType\":3,\"duration\":10.0,\"runParallel\":false}","{\"performers\":[1],\"lumiTalking\":true,\"redTalking\":false,\"greenTalking\":false,\"blueTalking\":false,\"purpleTalking\":false,\"dialogue\":\"В смысле?\",\"endWait\":30.0,\"playerSkippable\":false,\"runParallel\":false,\"continueAutomatically\":true}","{\"performers\":[5],\"lumiTalking\":false,\"redTalking\":false,\"greenTalking\":false,\"blueTalking\":false,\"purpleTalking\":true,\"dialogue\":\"А то, я же не просто кошка. А целая Реальность\",\"endWait\":30.0,\"playerSkippable\":false,\"runParallel\":false,\"continueAutomatically\":true}","{\"performers\":[1],\"lumiMoving\":true,\"redMoving\":false,\"greenMoving\":false,\"blueMoving\":false,\"purpleMoving\":false,\"moveType\":20,\"duration\":0.0,\"runParallel\":false}"],"prophecyTypeStrings":["ProphecySystem.MoveProphecy","ProphecySystem.TalkProphecy","ProphecySystem.TalkProphecy","ProphecySystem.TalkProphecy","ProphecySystem.EffectProphecy","ProphecySystem.TalkProphecy","ProphecySystem.TalkProphecy","ProphecySystem.EmoteProphecy","ProphecySystem.WaitProphecy","ProphecySystem.TalkProphecy","ProphecySystem.TalkProphecy","ProphecySystem.EmoteProphecy","ProphecySystem.TalkProphecy","ProphecySystem.TalkProphecy","ProphecySystem.MoveProphecy"],"removePlayerControlUntilTold":true,"companionActivated":false}

