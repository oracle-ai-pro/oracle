{"repeatable":false,"prophecyStrings":["{\"musicID\":14}","{\"performers\":[1],\"lumiTalking\":true,\"redTalking\":false,\"greenTalking\":false,\"blueTalking\":false,\"purpleTalking\":false,\"dialogue\":\"НУ, НАКОНЕЦ ТО, Я ВАС НАШЛА!\",\"endWait\":30.0,\"playerSkippable\":true,\"runParallel\":false,\"continueAutomatically\":true}","{\"performers\":[2,4],\"lumiEmoting\":false,\"redEmoting\":true,\"greenEmoting\":false,\"blueEmoting\":true,\"purpleEmoting\":false,\"emoteType\":5,\"duration\":10.0,\"runParallel\":true}","{\"performers\":[2,4],\"lumiTalking\":false,\"redTalking\":true,\"greenTalking\":false,\"blueTalking\":true,\"purpleTalking\":false,\"dialogue\":\"Безусловно. Мы рады наконец-то встретить тебя\",\"endWait\":30.0,\"playerSkippable\":true,\"runParallel\":false,\"continueAutomatically\":true}","{\"performers\":[1],\"lumiTalking\":true,\"redTalking\":false,\"greenTalking\":false,\"blueTalking\":false,\"purpleTalking\":false,\"dialogue\":\"А что с Зелёной Кошкой?\",\"endWait\":30.0,\"playerSkippable\":true,\"runParallel\":false,\"continueAutomatically\":true}","{\"performers\":[3],\"lumiEmoting\":false,\"redEmoting\":false,\"greenEmoting\":true,\"blueEmoting\":false,\"purpleEmoting\":false,\"emoteType\":3,\"duration\":10.0,\"runParallel\":true}","{\"performers\":[4],\"lumiTalking\":false,\"redTalking\":false,\"greenTalking\":false,\"blueTalking\":true,\"purpleTalking\":false,\"dialogue\":\"У нас к тебе очень плохие новости...\",\"endWait\":30.0,\"playerSkippable\":true,\"runParallel\":false,\"continueAutomatically\":true}","{\"performers\":[1],\"lumiTalking\":true,\"redTalking\":false,\"greenTalking\":false,\"blueTalking\":false,\"purpleTalking\":false,\"dialogue\":\"Только не говорите, что...\",\"endWait\":1.0,\"playerSkippable\":true,\"runParallel\":false,\"continueAutomatically\":true}","{\"performers\":[2],\"lumiTalking\":false,\"redTalking\":true,\"greenTalking\":false,\"blueTalking\":false,\"purpleTalking\":false,\"dialogue\":\"К сожалению, Зелёная кошка уже свободна и она здесь покидает это ужасное измерение\",\"endWait\":30.0,\"playerSkippable\":true,\"runParallel\":false,\"continueAutomatically\":true}","{\"performers\":[1],\"lumiFace\":true,\"redFace\":false,\"greenFace\":false,\"blueFace\":false,\"faceType\":6,\"duration\":0.0,\"runParallel\":true}","{\"performers\":[1],\"lumiTalking\":true,\"redTalking\":false,\"greenTalking\":false,\"blueTalking\":false,\"purpleTalking\":false,\"dialogue\":\"Вввсмысле... Ккак?!\",\"endWait\":30.0,\"playerSkippable\":false,\"runParallel\":false,\"continueAutomatically\":true}","{\"performers\":[4],\"lumiTalking\":false,\"redTalking\":false,\"greenTalking\":false,\"blueTalking\":true,\"purpleTalking\":false,\"dialogue\":\"Зелёная Кошка пыталась с самого начала этого мира тебя предупредить о том что она уходит. Но Фиолетовая Сущность просто сумасшедшая и скрывает все ее разговоры от тебя!\",\"endWait\":30.0,\"playerSkippable\":true,\"runParallel\":false,\"continueAutomatically\":true}","{\"performers\":[2],\"lumiTalking\":false,\"redTalking\":true,\"greenTalking\":false,\"blueTalking\":false,\"purpleTalking\":false,\"dialogue\":\"Зелёная пообещала что когда она выйдет из измерения, будет ждать нас.\",\"endWait\":30.0,\"playerSkippable\":true,\"runParallel\":false,\"continueAutomatically\":true}","{\"performers\":[2],\"lumiTalking\":false,\"redTalking\":true,\"greenTalking\":false,\"blueTalking\":false,\"purpleTalking\":false,\"dialogue\":\"**Все будет хорошо!**\",\"endWait\":30.0,\"playerSkippable\":false,\"runParallel\":false,\"continueAutomatically\":true}","{\"performers\":[3],\"lumiEmoting\":false,\"redEmoting\":false,\"greenEmoting\":true,\"blueEmoting\":false,\"purpleEmoting\":false,\"emoteType\":2,\"duration\":10.0,\"runParallel\":true}","{\"performers\":[1],\"lumiEmoting\":true,\"redEmoting\":false,\"greenEmoting\":false,\"blueEmoting\":false,\"purpleEmoting\":false,\"emoteType\":5,\"duration\":21.0,\"runParallel\":true}","{\"performers\":[2,4],\"lumiTalking\":false,\"redTalking\":true,\"greenTalking\":false,\"blueTalking\":true,\"purpleTalking\":false,\"dialogue\":\"Ладно, увидимся ещё.\",\"endWait\":30.0,\"playerSkippable\":true,\"runParallel\":false,\"continueAutomatically\":true}","{\"performers\":[2,3,4],\"lumiMoving\":false,\"redMoving\":true,\"greenMoving\":true,\"blueMoving\":true,\"purpleMoving\":false,\"moveType\":10,\"duration\":0.0,\"runParallel\":false}","{\"duration\":6.0}","{\"performers\":[3],\"lumiMoving\":false,\"redMoving\":false,\"greenMoving\":true,\"blueMoving\":false,\"purpleMoving\":false,\"moveType\":0,\"duration\":0.0,\"runParallel\":false}","{\"performers\":[3],\"lumiEmoting\":false,\"redEmoting\":false,\"greenEmoting\":true,\"blueEmoting\":false,\"purpleEmoting\":false,\"emoteType\":5,\"duration\":10.0,\"runParallel\":false}","{\"performers\":[3],\"lumiEmoting\":false,\"redEmoting\":false,\"greenEmoting\":true,\"blueEmoting\":false,\"purpleEmoting\":false,\"emoteType\":2,\"duration\":10.0,\"runParallel\":false}","{\"effectType\":1,\"duration\":6.0,\"runParallel\":true}","{\"performers\":[3],\"lumiMoving\":false,\"redMoving\":false,\"greenMoving\":true,\"blueMoving\":false,\"purpleMoving\":false,\"moveType\":101,\"duration\":0.0,\"runParallel\":false}","{\"duration\":13.0}","{\"performers\":[1],\"lumiMoving\":true,\"redMoving\":false,\"greenMoving\":false,\"blueMoving\":false,\"purpleMoving\":false,\"moveType\":10,\"duration\":0.0,\"runParallel\":false}"],"prophecyTypeStrings":["ProphecySystem.MusicProphecy","ProphecySystem.TalkProphecy","ProphecySystem.EmoteProphecy","ProphecySystem.TalkProphecy","ProphecySystem.TalkProphecy","ProphecySystem.EmoteProphecy","ProphecySystem.TalkProphecy","ProphecySystem.TalkProphecy","ProphecySystem.TalkProphecy","ProphecySystem.FaceProphecy","ProphecySystem.TalkProphecy","ProphecySystem.TalkProphecy","ProphecySystem.TalkProphecy","ProphecySystem.TalkProphecy","ProphecySystem.EmoteProphecy","ProphecySystem.EmoteProphecy","ProphecySystem.TalkProphecy","ProphecySystem.Mo