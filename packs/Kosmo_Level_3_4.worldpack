{"repeatable":false,"prophecyStrings":["{\"performers\":[1],\"lumiMoving\":true,\"redMoving\":false,\"greenMoving\":false,\"blueMoving\":false,\"purpleMoving\":false,\"moveType\":0,\"duration\":0.0,\"runParallel\":false}","{\"performers\":[5],\"lumiTalking\":false,\"redTalking\":false,\"greenTalking\":false,\"blueTalking\":false,\"purpleTalking\":true,\"dialogue\":\"Стоп, стоп стоп. Теперь я управляю тобой! Я имею право останавливать тебя, и сейчас я отключю тебе управление.\",\"endWait\":31.0,\"playerSkippable\":false,\"runParallel\":false,\"continueAutomatically\":true}","{\"performers\":[1],\"lumiTalking\":true,\"redTalking\":false,\"greenTalking\":false,\"blueTalking\":false,\"purpleTalking\":false,\"dialogue\":\"Нет!\",\"endWait\":30.0,\"playerSkippable\":false,\"runParallel\":false,\"continueAutomatically\":true}","{\"performers\":[5],\"lumiTalking\":false,\"redTalking\":false,\"greenTalking\":false,\"blueTalking\":false,\"purpleTalking\":true,\"dialogue\":\"Знаешь, так говоришь, будто ты хочешь на свободу?\",\"endWait\":31.0,\"playerSkippable\":false,\"runParallel\":false,\"continueAutomatically\":true}","{\"performers\":[1],\"lumiTalking\":true,\"redTalking\":false,\"greenTalking\":false,\"blueTalking\":false,\"purpleTalking\":false,\"dialogue\":\"Да я хочу на свободу!\",\"endWait\":27.0,\"playerSkippable\":false,\"runParallel\":false,\"continueAutomatically\":true}","{\"performers\":[5],\"lumiTalking\":false,\"redTalking\":false,\"greenTalking\":false,\"blueTalking\":false,\"purpleTalking\":true,\"dialogue\":\"Отлично, Но только ты пройдешь 12 мир и отпущю (хихи)\",\"endWait\":27.0,\"playerSkippable\":false,\"runParallel\":false,\"continueAutomatically\":true}","{\"performers\":[2,3,4],\"lumiMoving\":false,\"redMoving\":true,\"greenMoving\":true,\"blueMoving\":true,\"purpleMoving\":false,\"moveType\":101,\"duration\":0.0,\"runParallel\":true}","{\"performers\":[5],\"lumiTalking\":false,\"redTalking\":false,\"greenTalking\":false,\"blueTalking\":false,\"purpleTalking\":true,\"dialogue\":\"А твои друзья уже на свободе\",\"endWait\":34.0,\"playerSkippable\":false,\"runParallel\":true,\"continueAutomatically\":true}","{\"effectType\":1,\"duration\":4.0,\"runParallel\":false}","{\"themeID\":11}","{\"duration\":25.0}","{\"performers\":[5],\"lumiTalking\":false,\"redTalking\":false,\"greenTalking\":false,\"blueTalking\":false,\"purpleTalking\":true,\"dialogue\":\"Это мои Муляжы, Я так долго слежу за вами, что уже имею, целый пазл вашых способностей\",\"endWait\":30.0,\"playerSkippable\":false,\"runParallel\":false,\"continueAutomatically\":true}","{\"performers\":[1],\"lumiTalking\":true,\"redTalking\":false,\"greenTalking\":false,\"blueTalking\":false,\"purpleTalking\":false,\"dialogue\":\"Отдай мне этот пазл!\",\"endWait\":30.0,\"playerSkippable\":false,\"runParallel\":false,\"continueAutomatically\":true}","{\"performers\":[1,5],\"lumiMoving\":true,\"redMoving\":false,\"greenMoving\":false,\"blueMoving\":false,\"purpleMoving\":true,\"moveType\":20,\"duration\":0.0,\"runParallel\":false}"],"prophecyTypeStrings":["ProphecySystem.MoveProphecy","ProphecySystem.TalkProphecy","ProphecySystem.TalkProphecy","ProphecySystem.TalkProphecy","ProphecySystem.TalkProphecy","ProphecySystem.TalkProphecy","ProphecySystem.MoveProphecy","ProphecySystem.TalkProphecy","ProphecySystem.EffectProphecy","ProphecySystem.ThemeProphecy","ProphecySystem.WaitProphecy","ProphecySystem.TalkProphecy","ProphecySystem.TalkProphecy","ProphecySystem.MoveProphecy"],"removePlayerControlUntilTold":true,"companionActivated":false}

